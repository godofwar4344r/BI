# BI backend
BI_ENVIRONMENT=development
# Leave unset to use the repo-local SQLite default.
# BI_DATABASE_URL=sqlite:///./backend/data/bi.db
BI_VECTOR_STORE=local
BI_QDRANT_URL=http://localhost:6333
BI_QDRANT_COLLECTION=bi_decision_cases
BI_EMBEDDING_PROVIDER=hash
BI_EMBEDDING_DIMENSIONS=384
BI_RETRIEVAL_TOP_K=6
BI_RATE_LIMIT_PER_MINUTE=60
BI_ALLOW_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# BI frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
